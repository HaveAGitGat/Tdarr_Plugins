/* eslint-disable */
const details = () => {
  return {
    id: 'Modified_Tdarr_Plugin_vdka_Tiered_QSV_ICQ_BASED_CONFIGURABLE',
    Stage: 'Pre-processing',
    Name: 'Modified_Tiered FFMPEG+QSV ICQ (CRF-like) BASED CONFIGURABLE',
    Type: 'Video',
    Operation: 'Transcode',
    Description: `[Contains built-in filter] This plugin uses different ICQ (QSV constant-quality) values (similar to CRF)
depending on resolution. The ICQ/global_quality value is configurable per resolution.
FFmpeg preset can be configured, uses slow by default.
ALL OPTIONS MUST BE CONFIGURED UNLESS MARKED OPTIONAL!
If files are not in HEVC they will be transcoded.
The output container is mkv.\n\n`,
    Version: '1.10',
    Tags: 'pre-processing,ffmpeg,video only,qsv h265,configurable',

    Inputs: [
      {
        name: 'sdCQV',
        type: 'string',
        defaultValue: '21',
        inputUI: { type: 'text' },
        tooltip: `ICQ/global_quality for 480p/576p content.\nExample: 21`
      },
      {
        name: 'hdCQV',
        type: 'string',
        defaultValue: '23',
        inputUI: { type: 'text' },
        tooltip: `ICQ/global_quality for 720p content.\nExample: 23`
      },
      {
        name: 'fullhdCQV',
        type: 'string',
        defaultValue: '25',
        inputUI: { type: 'text' },
        tooltip: `ICQ/global_quality for 1080p content.\nExample: 25`
      },
      {
        name: 'uhdCQV',
        type: 'string',
        defaultValue: '28',
        inputUI: { type: 'text' },
        tooltip: `ICQ/global_quality for 4K/UHD content.\nExample: 28`
      },
      {
        name: 'bframe',
        type: 'string',
        defaultValue: '0',
        inputUI: { type: 'text' },
        tooltip: `Number of B-frames (0–3 recommended for QSV, higher may be supported on newer iGPUs).\nExample: 3`
      },
      {
        name: 'ffmpeg_preset',
        type: 'string',
        defaultValue: 'slow',
        inputUI: { type: 'text' },
        tooltip: `OPTIONAL. Defaults to slow.\nExamples: slow, medium, fast, veryfast`
      }
    ]
  }
}

// eslint-disable-next-line no-unused-vars
const plugin = (file, librarySettings, inputs, otherArguments) => {
  const lib = require('../methods/lib')();
  const os = require('os');

  inputs = lib.loadDefaultValues(inputs, details);

  let transcode = 0;
  let subcli = `-c:s copy`;
  let maxmux = '';
  let map = '-map 0';
  let cqvinuse = '';

  let response = {
    processFile: false,
    preset: '',
    container: '.mkv',
    handBrakeMode: false,
    FFmpegMode: false,
    reQueueAfter: true,
    infoLog: '',
  };

  // Must be video
  if (file.fileMedium !== 'video') {
    response.infoLog += '☒File is not a video!\n';
    return response;
  } else {
    response.infoLog += '☑File is a video!\n';
  }

  // Skip if already HEVC
  if (file.ffProbeData.streams[0].codec_name === 'hevc') {
    response.infoLog += '☑File is already in HEVC!\n';
    return response;
  }

  // FFmpeg preset
  let ffmpeg_preset = inputs.ffmpeg_preset || 'slow';
  response.infoLog += `☑Preset set as ${ffmpeg_preset}\n`;

  // Subtitle and muxing logic
  for (let i = 0; i < file.ffProbeData.streams.length; i++) {
    try {
      if (
        file.ffProbeData.streams[i].codec_name.toLowerCase() === 'mov_text' &&
        file.ffProbeData.streams[i].codec_type.toLowerCase() === 'subtitle'
      ) {
        subcli = `-c:s srt`;
      }
    } catch (err) {}

    try {
      if (
        file.ffProbeData.streams[i].codec_name.toLowerCase() === 'truehd' ||
        (file.ffProbeData.streams[i].codec_name.toLowerCase() === 'dts' &&
          file.ffProbeData.streams[i].profile &&
          file.ffProbeData.streams[i].profile.toLowerCase() === 'dts-hd ma') ||
        (file.ffProbeData.streams[i].codec_name.toLowerCase() === 'aac' &&
          file.ffProbeData.streams[i].sample_rate &&
          file.ffProbeData.streams[i].sample_rate.toLowerCase() === '44100' &&
          file.ffProbeData.streams[i].codec_type.toLowerCase() === 'audio')
      ) {
        maxmux = ` -max_muxing_queue_size 9999`;
      }
    } catch (err) {}

    try {
      if (
        ['png', 'bmp', 'mjpeg'].includes(
          file.ffProbeData.streams[i].codec_name.toLowerCase()
        ) &&
        file.ffProbeData.streams[i].codec_type.toLowerCase() === 'video'
      ) {
        map = `-map 0:v:0 -map 0:a -map 0:s?`;
      }
    } catch (err) {}
  }

  // --- QSV-specific: detect CPU generation for lookahead ---
  let cpuModel = '';
  try {
    cpuModel = os.cpus()[0].model || '';
  } catch (err) {
    cpuModel = '';
  }

  let supportsLookahead = false;

  // Very simple heuristic: assume 11th gen and newer support HEVC lookahead reliably
  const modelLower = cpuModel.toLowerCase();
  if (
    modelLower.includes('11th gen') ||
    modelLower.includes('12th gen') ||
    modelLower.includes('13th gen') ||
    modelLower.includes('14th gen') ||
    /i[3579]-11/.test(cpuModel) ||
    /i[3579]-12/.test(cpuModel) ||
    /i[3579]-13/.test(cpuModel) ||
    /i[3579]-14/.test(cpuModel)
  ) {
    supportsLookahead = true;
  }

  const lookaheadFlag = supportsLookahead ? '-look_ahead 1' : '-look_ahead 0';
  response.infoLog += `☑CPU model detected as: "${cpuModel}", QSV lookahead: ${supportsLookahead ? 'enabled' : 'disabled'}\n`;

  // --- Resolution-based ICQ selection (only picks cqvinuse here) ---
  const encoder = 'hevc_qsv';

  if (file.video_resolution === '480p' || file.video_resolution === '576p') {
    cqvinuse = inputs.sdCQV;
    transcode = 1;
  } else if (file.video_resolution === '720p') {
    cqvinuse = inputs.hdCQV;
    transcode = 1;
  } else if (file.video_resolution === '1080p') {
    cqvinuse = inputs.fullhdCQV;
    transcode = 1;
  } else if (file.video_resolution === '4KUHD') {
    cqvinuse = inputs.uhdCQV;
    transcode = 1;
  }

  // --- Build single FFmpeg command once, using selected cqvinuse ---
  if (transcode === 1) {
    // QSV ICQ: CRF-like rate control
    const videoCli =
      `${map} -dn -c:v ${encoder}` +
      ` -rc icq -global_quality ${cqvinuse} -b:v 0 ${lookaheadFlag}` +
      ` -preset ${ffmpeg_preset} -bf ${inputs.bframe}` +
      ` -c:a copy ${subcli}${maxmux}`;

    response.preset += `,${videoCli}`;
    response.processFile = true;
    response.FFmpegMode = true;
    response.reQueueAfter = true;
    response.infoLog += `☑File is ${file.video_resolution}, using QSV ICQ/global_quality value of ${cqvinuse}!\n`;
    response.infoLog += `☒File is not HEVC!\n`;
    response.infoLog += `File is being transcoded with hevc_qsv (ICQ mode)!\n`;
  }

  return response;
};

module.exports.details = details;
module.exports.plugin = plugin;
